APP_NAME="Project Management"
APP_ENV=production
APP_KEY=                          # Generate dengan: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://yourdomain.com    # Ganti dengan domain Cloudflare Anda
APP_TIMEZONE=Asia/Jakarta

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ── Database ─────────────────────────────────────────────────────────────────
# DB_HOST harus "db" karena itu nama service MySQL di docker-compose
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=dewakoding_project_management
DB_USERNAME=laravel
DB_PASSWORD=GANTI_PASSWORD_KUAT_DISINI

# ── Session & Cache ──────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# ── Mail ─────────────────────────────────────────────────────────────────────
# Untuk development: gunakan MAIL_MAILER=log (tidak perlu SMTP)
# Untuk production: ganti dengan SMTP Gmail / Mailgun / dll
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=youremail@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_FROM_ADDRESS=youremail@gmail.com
MAIL_FROM_NAME="${APP_NAME}"

# ── Google OAuth (opsional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Cloudflare Tunnel ────────────────────────────────────────────────────────
# Dapatkan token dari: Cloudflare Dashboard → Zero Trust → Networks → Tunnels
# Buat tunnel baru → copy "tunnel token" yang diberikan
CLOUDFLARE_TUNNEL_TOKEN=eyJhIjoiXXXXXXXXXXXX...    # Ganti dengan token asli Anda

# ── Vite ─────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
